        private Color ObtenerColorTextoSobreFondo(Color fondo)
        {
            int brillo =
                (fondo.R * 299 + fondo.G * 587 + fondo.B * 114) / 1000;

            if (brillo > 150)
            {
                return Color.FromArgb(25, 25, 25);
            }

            return Color.White;
        }


            }

            row.Cells["EquationKey"].Value = ecuacion.Clave ?? "";
            row.Cells["EcuacionProductiva"].Value = texto;
            row.Cells["VariablesEcuacion"].Value = ecuacion.Variables ?? "";
            row.Cells["ImpactoEcuacion"].Value = ecuacion.Impacto ?? "";

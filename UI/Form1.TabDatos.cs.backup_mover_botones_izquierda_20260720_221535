        private void AplicarDetalleEcuacionPipeline(DataGridViewRow row, bool sobrescribir)
        {
            if (row == null || row.IsNewRow)
            {
                return;
            }

            EcuacionProductivaDefinicion ecuacion = ObtenerEcuacionFilaPipeline(row);


        private void RefrescarComboCargosPermitidosEcuacion()
        {
            string seleccionActual = ObtenerNombreCompletoCargoSeleccionadoEcuacion();
            List<CategoriaTrabajador> biblioteca = Cargos.CrearBibliotecaCompleta()
                .Where(c => c != null && !string.IsNullOrWhiteSpace(c.Nombre))
                .ToList();

            CategoriaTrabajador actual = BuscarCargoRenderizadoEcuacion(
                biblioteca,
                seleccionActual
            );

            cmbCargoPermitidoEcuacion.SelectedIndexChanged -= CmbCargoPermitidoEcuacion_SelectedIndexChanged;
            try
            {
                cmbCargoPermitidoEcuacion.DropDownStyle = ComboBoxStyle.DropDownList;
                cmbCargoPermitidoEcuacion.Items.Clear();
                cmbCargoPermitidoEcuacion.Items.Add(TextoSeleccionarCargoEcuacion);

                foreach (string nombre in biblioteca
                    .Select(c => c.Nombre.Trim())
                    .Where(n => !string.IsNullOrWhiteSpace(n))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(n => n))
                {
                    cmbCargoPermitidoEcuacion.Items.Add(nombre);
                }

                string nombreActual = actual?.Nombre;
                int indice = string.IsNullOrWhiteSpace(nombreActual)
                    ? 0
                    : cmbCargoPermitidoEcuacion.FindStringExact(nombreActual);

                cmbCargoPermitidoEcuacion.SelectedIndex = indice >= 0 ? indice : 0;
                RefrescarNivelesCargoPermitidoEcuacion(actual?.Nivel);
            }
            finally
            {
                cmbCargoPermitidoEcuacion.SelectedIndexChanged += CmbCargoPermitidoEcuacion_SelectedIndexChanged;
            }
        }


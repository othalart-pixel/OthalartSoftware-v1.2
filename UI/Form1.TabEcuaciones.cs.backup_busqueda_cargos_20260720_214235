        private CargoParticipanteFormula MostrarDialogoCargoParticipante(CargoParticipanteFormula participante)
        {
            CargoParticipanteFormula trabajo = participante == null
                ? new CargoParticipanteFormula()
                : new CargoParticipanteFormula
                {
                    Cargo = participante.Cargo,
                    TarifaDiariaCLP = participante.TarifaDiariaCLP,
                    HorasPorDia = participante.HorasPorDia,
                    DedicacionPorcentaje = participante.DedicacionPorcentaje,
                    ModoCalculo = participante.ModoCalculo,
                    VariableBase = participante.VariableBase,
                    CantidadFactor = participante.CantidadFactor,
                    FormulaPersonalizada = participante.FormulaPersonalizada
                };

            List<CategoriaTrabajador> bibliotecaCargos = Cargos.CrearBibliotecaCompleta()
                .Where(c => c != null && !string.IsNullOrWhiteSpace(c.Nombre))
                .ToList();
            CategoriaTrabajador cargoInicial =
                BuscarCargoRenderizadoEcuacion(bibliotecaCargos, trabajo.Cargo);

            Form dialogo = new Form();
            dialogo.Text = "Configurar dedicacion del cargo";
            dialogo.StartPosition = FormStartPosition.CenterParent;
            dialogo.FormBorderStyle = FormBorderStyle.FixedDialog;
            dialogo.MaximizeBox = false;
            dialogo.MinimizeBox = false;
            dialogo.ClientSize = new Size(680, 465);

            TableLayoutPanel tabla = new TableLayoutPanel();
            tabla.Dock = DockStyle.Fill;
            tabla.Padding = new Padding(18);
            tabla.ColumnCount = 2;
            tabla.RowCount = 10;
            tabla.ColumnStyles.Add(new ColumnStyle(SizeType.Absolute, 210));
            tabla.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100));
            dialogo.Controls.Add(tabla);

            ComboBox cmbCargo = new ComboBox();
            cmbCargo.DropDownStyle = ComboBoxStyle.DropDownList;
            cmbCargo.Dock = DockStyle.Fill;
            foreach (string nombre in bibliotecaCargos
                .Select(c => c.Nombre.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(n => n))
            {
                cmbCargo.Items.Add(nombre);
            }

            ComboBox cmbNivel = new ComboBox();
            cmbNivel.DropDownStyle = ComboBoxStyle.DropDownList;
            cmbNivel.Dock = DockStyle.Fill;

            Action<string> cargarNiveles = nivelPreferido =>
            {
                string nombre = (cmbCargo.Text ?? "").Trim();
                cmbNivel.Items.Clear();

                List<string> niveles = bibliotecaCargos
                    .Where(c => string.Equals(c.Nombre, nombre, StringComparison.OrdinalIgnoreCase))
                    .Select(c => (c.Nivel ?? "").Trim())
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(NivelCargoOrden)
                    .ThenBy(n => n)
                    .ToList();

                if (niveles.Count == 0)
                {
                    niveles.Add("");
                }

                foreach (string nivel in niveles)
                {
                    cmbNivel.Items.Add(string.IsNullOrWhiteSpace(nivel) ? "Sin nivel" : nivel);
                }

                int indice = string.IsNullOrWhiteSpace(nivelPreferido)
                    ? -1
                    : cmbNivel.FindStringExact(nivelPreferido);

                if (indice < 0)
                {
                    indice = niveles.FindIndex(n =>
                        string.Equals(n, "tÃ­pico", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(n, "tipico", StringComparison.OrdinalIgnoreCase));
                }

                cmbNivel.SelectedIndex = indice >= 0 ? indice : 0;
            };

            if (cargoInicial != null)
            {
                int indiceCargo = cmbCargo.FindStringExact(cargoInicial.Nombre);
                cmbCargo.SelectedIndex = indiceCargo >= 0 ? indiceCargo : 0;
                cargarNiveles(cargoInicial.Nivel);
            }
            else if (cmbCargo.Items.Count > 0)
            {
                cmbCargo.SelectedIndex = 0;
                cargarNiveles("");
            }

            Func<CategoriaTrabajador> obtenerCargoSeleccionado = () =>
            {
                string nivel = (cmbNivel.Text ?? "").Trim();
                if (string.Equals(nivel, "Sin nivel", StringComparison.OrdinalIgnoreCase))
                {
                    nivel = "";
                }

                return bibliotecaCargos.FirstOrDefault(c =>
                    string.Equals(c.Nombre, cmbCargo.Text, StringComparison.OrdinalIgnoreCase) &&
                    string.Equals((c.Nivel ?? "").Trim(), nivel, StringComparison.OrdinalIgnoreCase));
            };

            ComboBox cmbModo = new ComboBox();
            cmbModo.DropDownStyle = ComboBoxStyle.DropDownList;
            cmbModo.Dock = DockStyle.Fill;
            cmbModo.Items.AddRange(ModosCalculoCargoParticipante);
            int indiceModo = cmbModo.FindStringExact(trabajo.ModoCalculo);
            cmbModo.SelectedIndex = indiceModo >= 0 ? indiceModo : 0;

            ComboBox cmbVariable = new ComboBox();
            cmbVariable.DropDownStyle = ComboBoxStyle.DropDown;
            cmbVariable.Dock = DockStyle.Fill;
            foreach (object variable in lstEcuacionVariables.Items)
            {
                cmbVariable.Items.Add(Convert.ToString(variable) ?? "");
            }
            cmbVariable.Text = trabajo.VariableBase ?? "";

            NumericUpDown nudDedicacion = CrearNumericDialogo(0, 500, 100, 5, 2);
            nudDedicacion.Value = (decimal)Math.Max(0, Math.Min(500,
                trabajo.DedicacionPorcentaje <= 0 ? 100 : trabajo.DedicacionPorcentaje));

            NumericUpDown nudTarifa = CrearNumericDialogo(0, 100000000, 0, 1000, 0);
            nudTarifa.Value = (decimal)Math.Max(0, Math.Min(100000000, trabajo.TarifaDiariaCLP));

            NumericUpDown nudHorasDia = CrearNumericDialogo(0.1M, 24, 8, 0.5M, 2);
            nudHorasDia.Value = (decimal)Math.Max(0.1, Math.Min(24,
                trabajo.HorasPorDia <= 0 ? 8 : trabajo.HorasPorDia));

            NumericUpDown nudFactor = CrearNumericDialogo(0, 1000000, 1, 0.25M, 2);

        private void RefrescarNivelesCargoPermitidoEcuacion(string nivelPreferido = "")
        {
            string nombre = (cmbCargoPermitidoEcuacion.Text ?? "").Trim();
            cmbNivelCargoPermitidoEcuacion.Items.Clear();

            if (string.IsNullOrWhiteSpace(nombre) ||
                string.Equals(nombre, TextoSeleccionarCargoEcuacion, StringComparison.OrdinalIgnoreCase))
            {
                cmbNivelCargoPermitidoEcuacion.Enabled = false;
                return;
            }

            List<string> niveles = Cargos.CrearBibliotecaCompleta()
                .Where(c => c != null &&
                    string.Equals(c.Nombre, nombre, StringComparison.OrdinalIgnoreCase))
                .Select(c => (c.Nivel ?? "").Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(NivelCargoOrden)
                .ThenBy(n => n)
                .ToList();

            if (niveles.Count == 0)
            {
                niveles.Add("");
            }

            foreach (string nivel in niveles)
            {
                cmbNivelCargoPermitidoEcuacion.Items.Add(
                    string.IsNullOrWhiteSpace(nivel) ? "Sin nivel" : nivel
                );
            }

            cmbNivelCargoPermitidoEcuacion.Enabled = true;
            int indice = string.IsNullOrWhiteSpace(nivelPreferido)
                ? -1
                : cmbNivelCargoPermitidoEcuacion.FindStringExact(nivelPreferido);

            if (indice < 0)
            {
                indice = niveles.FindIndex(n =>
                    string.Equals(n, "tÃ­pico", StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(n, "tipico", StringComparison.OrdinalIgnoreCase));
            }

            cmbNivelCargoPermitidoEcuacion.SelectedIndex = indice >= 0 ? indice : 0;
        }

        private static int NivelCargoOrden(string nivel)
        {
            string normalizado = (nivel ?? "").Trim().ToLowerInvariant();
            if (normalizado == "junior") return 0;
            if (normalizado == "tÃ­pico" || normalizado == "tipico") return 1;
            if (normalizado == "senior") return 2;
            if (string.IsNullOrWhiteSpace(normalizado)) return 3;
            return 4;
        }

        private string ObtenerNombreCompletoCargoSeleccionadoEcuacion()
        {
            string nombre = (cmbCargoPermitidoEcuacion.Text ?? "").Trim();
            if (string.IsNullOrWhiteSpace(nombre) ||
                string.Equals(nombre, TextoSeleccionarCargoEcuacion, StringComparison.OrdinalIgnoreCase))
            {
                return "";
            }

            string nivel = (cmbNivelCargoPermitidoEcuacion.Text ?? "").Trim();
            if (string.Equals(nivel, "Sin nivel", StringComparison.OrdinalIgnoreCase))
            {
                nivel = "";
            }

            CategoriaTrabajador cargo = Cargos.CrearBibliotecaCompleta()
                .FirstOrDefault(c => c != null &&
                    string.Equals(c.Nombre, nombre, StringComparison.OrdinalIgnoreCase) &&
                    string.Equals((c.Nivel ?? "").Trim(), nivel, StringComparison.OrdinalIgnoreCase));

            return cargo == null
                ? (string.IsNullOrWhiteSpace(nivel) ? nombre : nombre + " (" + nivel + ")")
                : cargo.NombreCompleto;
        }
        private void AgregarCargoPermitidoEcuacion()
        {
            string valor = ObtenerNombreCompletoCargoSeleccionadoEcuacion();
            if (string.IsNullOrWhiteSpace(valor) ||
                string.Equals(valor, TextoSeleccionarCargoEcuacion, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            CargoPonderadoEcuacion cargoNuevo = new CargoPonderadoEcuacion
            {
                Cargo = valor,
                Ponderador = (double)nudPonderadorCargoEcuacion.Value
            };

            bool existe = lstEcuacionCargosPermitidos.Items
                .Cast<object>()
                .Select(ObtenerCargoPonderadoEcuacion)
                .Any(i => string.Equals(i.Cargo, valor, StringComparison.OrdinalIgnoreCase));

            if (existe)
            {
                for (int i = 0; i < lstEcuacionCargosPermitidos.Items.Count; i++)
                {
                    CargoPonderadoEcuacion existente =
                        ObtenerCargoPonderadoEcuacion(lstEcuacionCargosPermitidos.Items[i]);

                    if (string.Equals(existente.Cargo, valor, StringComparison.OrdinalIgnoreCase))
                    {
                        lstEcuacionCargosPermitidos.Items[i] = cargoNuevo;
                        lstEcuacionCargosPermitidos.SelectedIndex = i;
                        break;
                    }
                }
            }
            else
            {
                lstEcuacionCargosPermitidos.Items.Add(cargoNuevo);
            }

            cmbCargoPermitidoEcuacion.SelectedIndex =
                cmbCargoPermitidoEcuacion.Items.Count > 0 ? 0 : -1;
            nudPonderadorCargoEcuacion.Value = 1M;
            ActualizarResumenVectorCargosEcuacion();
            ActualizarRenderEcuacionProductiva();
        }

        private void AplicarPonderadorCargoSeleccionadoEcuacion()
        {
            int index = lstEcuacionCargosPermitidos.SelectedIndex;
            if (index < 0)
            {
                AgregarCargoPermitidoEcuacion();
                return;
            }

            CargoPonderadoEcuacion cargo =
                ObtenerCargoPonderadoEcuacion(lstEcuacionCargosPermitidos.Items[index]);

            if (!string.IsNullOrWhiteSpace(cmbCargoPermitidoEcuacion.Text))
            {
                cargo.Cargo = ObtenerNombreCompletoCargoSeleccionadoEcuacion();
            }

            cargo.Ponderador = (double)nudPonderadorCargoEcuacion.Value;
            lstEcuacionCargosPermitidos.Items[index] = cargo;
            lstEcuacionCargosPermitidos.SelectedIndex = index;
            ActualizarResumenVectorCargosEcuacion();
            ActualizarRenderEcuacionProductiva();
        }


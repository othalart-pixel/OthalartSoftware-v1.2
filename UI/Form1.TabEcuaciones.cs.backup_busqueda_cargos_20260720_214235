                    cmbEcuacionBase.Items.Add(new OpcionFormulaMadreEcuacion
                    {
                        Clave = clave,
                        Nombre = nombre
                    });
                }
            }

            SeleccionarComboSeguro(cmbEcuacionBase, actual);
        }

        private void SeleccionarComboSeguro(ComboBox combo, string valor)
        {
            if (combo == cmbEcuacionBase)

                    AlternarExpansionTablaProductosProyecto(e.RowIndex);
                    return;
                }

                if (e.Button == MouseButtons.Left &&
                    e.RowIndex >= 0 &&
                    e.ColumnIndex >= 0 &&
                    !dgvProductosProyecto.IsCurrentCellInEditMode)
                {
                    AbrirInspectorProyecto(dgvProductosProyecto.Rows[e.RowIndex].Tag);

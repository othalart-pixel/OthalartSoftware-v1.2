            }
            if (sub.Procesos == null)
            {
                sub.Procesos = new List<ProcesoProyecto>();
            }

            ProcesoProyecto proceso = new ProcesoProyecto
            {
                Id = Guid.NewGuid().ToString("N"),
                ProcesoBibliotecaId = "",
                Nombre = "Nuevo proceso",
                EtapaId = "",
                SubetapaId = "",
                Activo = true,
                Resultado = new ResultadoProcesoProyecto()
            };

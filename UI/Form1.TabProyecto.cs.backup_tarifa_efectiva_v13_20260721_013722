        {
            Button b = new Button();
            b.Text = texto;
            b.Width = ancho;
            b.Height = 32;
            b.Margin = new Padding(0, 0, 8, 6);
            b.Font = new Font("Segoe UI", 8.9f, FontStyle.Bold);
            b.FlatStyle = FlatStyle.Flat;
            b.FlatAppearance.BorderColor = Color.FromArgb(175, 181, 190);
            b.BackColor = Color.White;
            b.Cursor = Cursors.Hand;
            b.Click += click;

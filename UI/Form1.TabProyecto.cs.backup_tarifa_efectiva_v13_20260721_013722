                if (dgvProductosProyecto.IsCurrentCellInEditMode)
                {
                    return;
                }

                if (dgvProductosProyecto.CurrentRow != null)
                {
                    object nodoSeleccionado = dgvProductosProyecto.CurrentRow.Tag;

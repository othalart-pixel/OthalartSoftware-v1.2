@echo off
setlocal EnableExtensions EnableDelayedExpansion

title Cotizador Othalart
cd /d "%~dp0"

echo.
echo ==========================================
echo        COTIZADOR OTHALART
echo ==========================================
echo.

where dotnet >nul 2>nul
if errorlevel 1 (
    echo ERROR: No se encontro dotnet.
    echo Instala o repara el SDK de .NET.
    echo.
    pause
    exit /b 1
)

set "CSPROJ="

if exist "OthalartSoftware v1.0.csproj" (
    set "CSPROJ=OthalartSoftware v1.0.csproj"
) else (
    for %%F in (*.csproj) do (
        if not defined CSPROJ set "CSPROJ=%%F"
    )
)

if not defined CSPROJ (
    echo ERROR: No se encontro ningun archivo .csproj.
    echo Este archivo debe estar en la carpeta raiz del proyecto.
    echo.
    pause
    exit /b 1
)

echo Proyecto detectado:
echo !CSPROJ!
echo.

taskkill /F /IM OthalartCotizadorDev.exe >nul 2>nul
taskkill /F /IM "OthalartSoftware v1.0.exe" >nul 2>nul

echo Compilando...
dotnet build "!CSPROJ!" -c Debug --nologo

if errorlevel 1 (
    echo.
    echo ==========================================
    echo ERROR DE COMPILACION
    echo ==========================================
    echo Revisa los errores mostrados arriba.
    echo.
    pause
    exit /b 1
)

set "EXE="

if exist "bin\Debug\net8.0-windows\OthalartCotizadorDev.exe" (
    set "EXE=bin\Debug\net8.0-windows\OthalartCotizadorDev.exe"
)

if not defined EXE (
    for /r "bin\Debug" %%F in (*.exe) do (
        echo %%~nxF | findstr /I /V "testhost apphost" >nul
        if not errorlevel 1 (
            if not defined EXE set "EXE=%%F"
        )
    )
)

if not defined EXE (
    echo.
    echo ERROR: Se compilo el proyecto pero no se encontro el ejecutable.
    echo Revisa la carpeta bin\Debug.
    echo.
    pause
    exit /b 1
)

echo.
echo Abriendo:
echo !EXE!
echo.

start "" "!EXE!"

if errorlevel 1 (
    echo.
    echo ERROR: Windows no pudo abrir el ejecutable.
    echo.
    pause
    exit /b 1
)

exit /b 0